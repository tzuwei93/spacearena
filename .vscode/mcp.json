{
  "mcpServers": {
    "unityMCP": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "mcpforunityserver==9.7.3",
        "mcp-for-unity",
        "--transport",
        "stdio"
      ]
    },
    "godot-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@yanhuifair/godot-mcp",
        "-p",
        "./GodotProject"
      ]
    }
  }
}
